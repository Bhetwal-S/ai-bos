# Copy this file to .env and fill in your values
# cp config/.env.example config/.env

# ── Required (Phase 1) ──────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Phase 2 Integrations (optional) ────────────────────────
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SENDGRID_API_KEY=
VERCEL_TOKEN=

# ── App config ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
